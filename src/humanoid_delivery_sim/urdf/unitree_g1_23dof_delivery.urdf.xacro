<robot name="g1_23dof_mode_10" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="mesh_dir" value="file://$(find humanoid_delivery_sim)/meshes/unitree_g1"/>
  <xacro:arg name="spawn_z" default="0.80"/>
  <material name="dark">
    <color rgba="0.2 0.2 0.2 1"/>
  </material>
  <material name="white">
    <color rgba="0.7 0.7 0.7 1"/>
