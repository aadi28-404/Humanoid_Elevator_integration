    <model name="guest_crossing">
      <static>true</static>
      <pose>2.1 0.7 0 0 0 -1.5708</pose>
      <link name="person">
        <visual name="standing_human">
          <pose>0 0 0.02 0.04 0 0</pose>
          <geometry>
            <mesh>
              <uri>model://gazebo_models/person_standing/meshes/standing.dae</uri>
            </mesh>
          </geometry>
        </visual>
        <collision name="standing_human_footprint">
          <pose>0 -0.1 0.9 0 0 0</pose>
          <geometry>
            <box><size>0.5 0.35 1.8</size></box>
          </geometry>
        </collision>
      </link>
