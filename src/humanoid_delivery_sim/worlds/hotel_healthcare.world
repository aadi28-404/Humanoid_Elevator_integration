        <visual name="west_wall"><pose>-2.5 0 1.1 0 0 0</pose><geometry><box><size>0.12 7.4 2.2</size></box></geometry><material><ambient>0.76 0.77 0.74 1</ambient></material></visual>
        <collision name="west_wall_col"><pose>-2.5 0 1.1 0 0 0</pose><geometry><box><size>0.12 7.4 2.2</size></box></geometry></collision>
        <visual name="east_wall"><pose>7.9 0 1.1 0 0 0</pose><geometry><box><size>0.12 7.4 2.2</size></box></geometry><material><ambient>0.76 0.77 0.74 1</ambient></material></visual>
        <collision name="east_wall_col"><pose>7.9 0 1.1 0 0 0</pose><geometry><box><size>0.12 7.4 2.2</size></box></geometry></collision>

