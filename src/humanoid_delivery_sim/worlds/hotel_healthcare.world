<?xml version="1.0"?>
<sdf version="1.6">
  <world name="hotel_healthcare">
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>
    <physics type="ode"><max_step_size>0.002</max_step_size><real_time_update_rate>500</real_time_update_rate></physics>
    <plugin name="hotel_gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/gazebo</namespace>
      </ros>
      <update_rate>20.0</update_rate>
    </plugin>

    <model name="hotel_floor_plan">
      <static>true</static>
      <link name="structure">
