        <visual name="right_door_open"><pose>0.03 -0.82 1 0 0 0</pose><geometry><box><size>0.08 0.06 2.0</size></box></geometry><material><ambient>0.82 0.84 0.86 1</ambient></material></visual>
        <collision name="right_door_open_col"><pose>0.03 -0.82 1 0 0 0</pose><geometry><box><size>0.08 0.06 2.0</size></box></geometry></collision>
        <visual name="panel"><pose>0.62 -0.48 1 0 0 0</pose><geometry><box><size>0.05 0.22 0.8</size></box></geometry><material><ambient>0.04 0.04 0.04 1</ambient></material></visual>
        <collision name="panel_col"><pose>0.62 -0.48 1 0 0 0</pose><geometry><box><size>0.05 0.22 0.8</size></box></geometry></collision>
        <visual name="panel_light"><pose>0.65 -0.48 1.2 0 0 0</pose><geometry><sphere><radius>0.045</radius></sphere></geometry><material><ambient>0.0 0.9 0.25 1</ambient></material></visual>
