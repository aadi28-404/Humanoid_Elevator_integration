        <visual name="delivery_marker"><pose>5.2 2.1 0.055 0 0 0</pose><geometry><box><size>0.9 0.9 0.035</size></box></geometry><material><ambient>0.10 0.36 0.85 1</ambient></material></visual>
        <visual name="safety_zone_marker"><pose>2.1 0.7 0.05 0 0 0</pose><geometry><cylinder><radius>0.9</radius><length>0.025</length></cylinder></geometry><material><ambient>0.75 0.10 0.08 0.45</ambient><diffuse>0.75 0.10 0.08 0.45</diffuse></material></visual>
