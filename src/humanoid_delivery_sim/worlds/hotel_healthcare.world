      </link>
    </model>

    <model name="medical_kit_pickup">
      <static>false</static>
      <pose>2.0 -2.55 0.96 0 0 0</pose>
      <link name="kit">
        <gravity>false</gravity>
        <visual name="blue_box"><pose>0 0 0 0 0 0</pose><geometry><box><size>0.24 0.18 0.12</size></box></geometry><material><ambient>0.05 0.32 0.95 1</ambient><diffuse>0.05 0.32 0.95 1</diffuse></material></visual>
      </link>
    </model>

    <model name="elevator_A">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="car">
        <visual name="floor_marker"><pose>0 0 0.065 0 0 0</pose><geometry><box><size>1.35 1.35 0.045</size></box></geometry><material><ambient>0.1 0.3 0.9 1</ambient><diffuse>0.1 0.3 0.9 1</diffuse></material></visual>
        <collision name="floor_marker_col"><pose>0 0 0.065 0 0 0</pose><geometry><box><size>1.35 1.35 0.045</size></box></geometry></collision>
        <visual name="back_wall"><pose>-0.68 0 1 0 0 0</pose><geometry><box><size>0.08 1.35 2.0</size></box></geometry><material><ambient>0.48 0.50 0.52 1</ambient></material></visual>
        <collision name="back_wall_col"><pose>-0.68 0 1 0 0 0</pose><geometry><box><size>0.08 1.35 2.0</size></box></geometry></collision>
        <visual name="left_door_open"><pose>0.03 0.82 1 0 0 0</pose><geometry><box><size>0.08 0.06 2.0</size></box></geometry><material><ambient>0.82 0.84 0.86 1</ambient></material></visual>
