        <collision name="room102_wall_left_col"><pose>4.55 -1.35 1.1 0 0 0</pose><geometry><box><size>0.3 0.08 2.2</size></box></geometry></collision>
        <visual name="room102_wall_right"><pose>6.0 -1.35 1.1 0 0 0</pose><geometry><box><size>0.8 0.08 2.2</size></box></geometry><material><ambient>0.72 0.73 0.70 1</ambient></material></visual>
        <collision name="room102_wall_right_col"><pose>6.0 -1.35 1.1 0 0 0</pose><geometry><box><size>0.8 0.08 2.2</size></box></geometry></collision>
